{
  "manifest_version": 3,
  "name": "Webpage to Markdown",
  "version": "0.0.1",
  "description": "Convert webpages to Markdown format",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert to Markdown"
  },
  "background": {
    "service_worker": "background.js"
  }
} 